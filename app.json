{
  "expo": {
    "name": "StudyPulse",
    "slug": "study-pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "studypulse",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.revuc.studypulse",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "StudyPulse uses the microphone so patients and clinicians can speak search queries for trial matching."
      }
    },
    "android": {
      "package": "com.revuc.studypulse",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-asset"
    ]
  }
}
